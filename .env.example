# Configuración general de la aplicación
APP_ENV=development
APP_DEBUG=true
APP_BASE_URL=http://localhost/neiva
APP_TIMEZONE=America/Bogota

# Almacenamiento y directorios
# PRIVATE_STORAGE_PATH: Ruta absoluta de almacenamiento seguro fuera del árbol web
PRIVATE_STORAGE_PATH=C:\neiva_private_storage
# TEMP_STORAGE_PATH: Opcional, por defecto usa <app_root>/tmp
TEMP_STORAGE_PATH=
# PRIVATE_DOCUMENTS_PATH: Opcional, por defecto usa <private_storage_path>/DOCUMENTOS
PRIVATE_DOCUMENTS_PATH=

# Configuración de base de datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=neiva
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_TIMEZONE=-05:00

# Parámetros del sistema y notificaciones
SYSTEM_EMAIL=soporte@arbimaps.com
SYSTEM_SECRET_KEY=some-random-32-character-secret-key
